SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=creditflow_senior
DB_USER=creditflow
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

REDIS_URL=redis://localhost:6379/1
CHANNEL_LAYERS_REDIS_URL=redis://localhost:6379/2
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Roadmap Этап 3 п.7-9: domain-event broker (outbox relay + saga consumer).
# memory:// (kombu's in-process transport) needs no running broker — fine for
# local `runserver`/tests. Set to a real RabbitMQ URL to exercise the saga
# end-to-end, e.g. amqp://guest:guest@localhost:5672//
EVENT_BROKER_URL=memory://

# Roadmap Этап 5 п.13: S3/MinIO object storage for avatars/documents.
# USE_S3=False (default) keeps local FileSystemStorage — no MinIO/Docker needed.
USE_S3=False
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=creditflow-documents
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_REGION_NAME=us-east-1
AWS_QUERYSTRING_EXPIRE=3600

# Roadmap Этап 5 п.14: read replica for heavy reports/admin analytics (audit
# log). Defaults to the primary DB_* values when unset (safe no-op locally).
REPLICA_DB_HOST=
REPLICA_DB_PORT=
REPLICA_DB_NAME=
REPLICA_DB_USER=
REPLICA_DB_PASSWORD=
