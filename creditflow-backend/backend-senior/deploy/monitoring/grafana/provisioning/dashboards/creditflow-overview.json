{
  "title": "CreditFlow Overview",
  "uid": "creditflow-overview",
  "timezone": "utc",
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "Applications submitted (rate/5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "rate(cf_applications_submitted_total[5m])", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Scoring duration (p50/p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(cf_scoring_duration_seconds_bucket[5m])) by (le))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(cf_scoring_duration_seconds_bucket[5m])) by (le))",
          "refId": "B",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Loans disbursed amount (rate/1h)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "rate(cf_loans_disbursed_amount_total[1h])", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "HTTP request duration p95 by endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(cf_http_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "refId": "A",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "HTTP 5xx rate by endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(cf_http_request_duration_seconds_count{status=~\"5..\"}[5m])) by (endpoint)",
          "refId": "A",
          "legendFormat": "{{endpoint}}"
        }
      ]
    }
  ]
}
