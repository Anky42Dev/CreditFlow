# deploy/.env.prod — copy to deploy/.env.prod and fill in real values.
# Consumed both by docker-compose.prod.yml's ${VAR} interpolation (db/minio
# creds) and by each service's `env_file: .env.prod` (Django settings).

SECRET_KEY=change-me-to-a-random-50-char-value
DEBUG=False
ALLOWED_HOSTS=creditflow.example.com
CSRF_TRUSTED_ORIGINS=https://creditflow.example.com
CORS_ALLOWED_ORIGINS=https://creditflow.example.com
SECURE_SSL_REDIRECT=True

DB_NAME=creditflow_senior
DB_USER=creditflow
DB_PASSWORD=change-me

AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_STORAGE_BUCKET_NAME=creditflow-documents
AWS_S3_REGION_NAME=us-east-1

GRAFANA_ADMIN_PASSWORD=change-me
