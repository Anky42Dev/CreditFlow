[run]
source = .
omit =
    */migrations/*
    */tests*
    */test_*
    manage.py
    config/asgi.py
    config/wsgi.py
    config/celery.py
    scoring_service/*
    */venv/*
    */.venv/*
    */site-packages/*

[report]
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
