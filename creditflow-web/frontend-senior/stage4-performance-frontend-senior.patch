+export const revalidate = 60;
+
+// DOC 6 §4: streaming SSR / RSC for the static part of the catalog — the
+// default (unfiltered, default-ordered) product list is public (backend
+// permission AllowAny, itself Redis-cached — see DOC 5 §8), so it's fetched
+// here on the server and streamed as part of the page instead of the client
+// mounting empty and firing its own request. Filtering/sorting stays fully
+// client-side via React Query, using this as `initialData` for the default
+// view only.
+async function fetchInitialProducts() {
+  const apiUrl = process.env.NEXT_PUBLIC_API_URL || "http://localhost:8000";
+  try {
+    const res = await fetch(`${apiUrl}/api/v1/credit-products`, {
+      next: { revalidate },
+    });
+    if (!res.ok) return null;
+    return await res.json();
+  } catch {
+    // Backend unreachable at build/request time — client will fetch as usual.
+    return null;
+  }
+}
+
+export default async function Page() {
+  const initialProducts = await fetchInitialProducts();
+  return <ProductsPage initialProducts={initialProducts} />;
 }
