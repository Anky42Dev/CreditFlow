diff --git a/src/shared/lib/resolveMediaUrl.js b/src/shared/lib/resolveMediaUrl.js
new file mode 100644
index 0000000..8a76292
--- /dev/null
+++ b/src/shared/lib/resolveMediaUrl.js
@@ -0,0 +1,12 @@
+// DOC 6 §4: DRF's ImageField.url can be relative ("/media/avatars/x.jpg") or
+// already absolute depending on whether the request had a scheme/host in
+// context. next/image needs an absolute URL (or a path matching a configured
+// remote pattern) to optimize it, so normalize here.
+export function resolveMediaUrl(url) {
+  if (!url) return null;
+  if (/^https?:\/\//i.test(url) || url.startsWith("blob:") || url.startsWith("data:")) {
+    return url;
+  }
+  const base = process.env.NEXT_PUBLIC_API_URL || "";
+  return `${base}${url.startsWith("/") ? "" : "/"}${url}`;
+}
