diff --git a/scripts/check-bundle-budget.mjs b/scripts/check-bundle-budget.mjs
new file mode 100644
index 0000000..6f80ac9
--- /dev/null
+++ b/scripts/check-bundle-budget.mjs
@@ -0,0 +1,83 @@
+#!/usr/bin/env node
+// DOC 6 §4/§10: "Bundle analysis — @next/bundle-analyzer в CI, бюджет на
+// размер чанков". Runs after `next build` and fails the build if the total
+// client JS or any single chunk grows past its budget, so regressions are
+// caught before they ship rather than noticed later in a Web Vitals
+// dashboard.
+//
+// Turbopack (this project's bundler) hashes chunk filenames without the
+// semantic "framework-"/"main-" prefixes Webpack used, so budgets here are
+// enforced per-chunk (catches one bloated chunk) and on the total (catches
+// death-by-a-thousand-cuts growth) rather than by filename pattern.
+//
+// Usage: runs automatically via `npm run build` (postbuild hook).
+
+import { readdirSync, statSync } from "node:fs";
+import { join } from "node:path";
+
+const CHUNKS_DIR = join(process.cwd(), ".next", "static", "chunks");
+
+// Calibrated with ~15% headroom over this app's current build. Bump these
+// deliberately when a real feature needs the room — not silently.
+const MAX_SINGLE_CHUNK_KB = 360;
+const MAX_TOTAL_KB = 1600;
+
+function walk(dir) {
+  let files = [];
+  for (const entry of readdirSync(dir, { withFileTypes: true })) {
+    const full = join(dir, entry.name);
+    if (entry.isDirectory()) {
+      files = files.concat(walk(full));
+    } else if (entry.name.endsWith(".js")) {
+      files.push(full);
+    }
+  }
+  return files;
+}
+
+function main() {
+  let files;
+  try {
+    files = walk(CHUNKS_DIR);
+  } catch {
+    console.warn(`[bundle-budget] ${CHUNKS_DIR} not found — run "next build" first. Skipping.`);
+    return;
+  }
+
+  const sizes = files.map((file) => ({
+    filename: file.split("/").pop(),
+    kb: statSync(file).size / 1024,
+  }));
+  const totalKb = sizes.reduce((sum, f) => sum + f.kb, 0);
+  const oversized = sizes.filter((f) => f.kb > MAX_SINGLE_CHUNK_KB);
+
+  const violations = [];
+  if (oversized.length > 0) {
+    violations.push(
+      ...oversized.map(
+        (f) => `  chunk ${f.filename}: ${f.kb.toFixed(1)} KB (budget ${MAX_SINGLE_CHUNK_KB} KB)`
+      )
+    );
+  }
+  if (totalKb > MAX_TOTAL_KB) {
+    violations.push(
+      `  total chunks: ${totalKb.toFixed(1)} KB (budget ${MAX_TOTAL_KB} KB)`
+    );
+  }
+
+  if (violations.length === 0) {
+    console.log(
+      `[bundle-budget] OK — ${files.length} chunks, ${totalKb.toFixed(1)} KB total (budget ${MAX_TOTAL_KB} KB).`
+    );
+    return;
+  }
+
+  console.error("[bundle-budget] Chunk size budget exceeded:");
+  violations.forEach((line) => console.error(line));
+  console.error(
+    "\nRun `npm run analyze` to inspect what pushed the bundle over budget."
+  );
+  process.exit(1);
+}
+
+main();
